{
  "name": "openspec-installer",
  "version": "1.0.0",
  "description": "Cross-platform bootstrap tool for openspec + Claude Code integration",
  "main": "dist/index.js",
  "bin": {
    "openspec-installer": "dist/index.js"
  },
  "files": [
    "dist/",
